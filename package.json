{
  "name": "cgil-log",
  "version": "4.0.1",
  "description": "Goeland client side log class (now with TypeScript)",
  "type": "module",
  "main": "dist/cgLog.cjs.js",
  "module": "dist/cgLog.esm.js",
  "browser": "dist/cgLog.umd.js",
  "types": "dist/index.d.ts",
  "files": [
    "/dist",
    "/examples",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/cgLog.esm.js",
      "require": "./dist/cgLog.cjs.js",
      "default": "./dist/cgLog.esm.js"
    }
  },
  "scripts": {
    "clean": "rm -rf dist/*",
    "build": "bun run build.ts && tsc",
    "dev": "bun run --watch build.ts",
    "examples": "python -m http.server",
    "prebuild": "npm run clean"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lao-tseu-is-alive/cgil-log.git"
  },
  "keywords": [
    "goeland",
    "javascript",
    "log",
    "dev"
  ],
  "author": "lao.tseu.is.alive@gmail.com",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/lao-tseu-is-alive/cgil-log/issues"
  },
  "homepage": "https://github.com/lao-tseu-is-alive/cgil-log#readme",
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "typescript": "^5.9.3"
  }
}
